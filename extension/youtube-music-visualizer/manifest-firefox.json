{
  "manifest_version": 2,
  "name": "YouTube Music Live 3D Visualizer",
  "version": "2.1.0",
  "description": "Visualiseur audio 3D en temps reel pour YouTube Music.",
  "permissions": [
    "https://music.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["visualizer.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    "visualizer.js"
  ]
}
