--q1
--in
SELECT c.NOM_COMMUNE 
FROM basetd.COMMUNE c
WHERE c.NOMDEP IN (SELECT d.NOMDEP FROM basetd.DEPARTEMENT d WHERE d.CODE_DEPARTEMENT = '49');
--exists
SELECT c.NOM_COMMUNE 
FROM basetd.COMMUNE c
WHERE EXISTS (SELECT * FROM basetd.DEPARTEMENT d WHERE c.NOMDEP = d.NOMDEP AND d.CODE_DEPARTEMENT = '49');
--2
--in 
SELECT c.NOM_COMMUNE, c.NOMDEP
FROM basetd.COMMUNE c
WHERE c.CODE_INSEE IN (
    SELECT di.CODE_INSEE 
    FROM basetd.DISTRIBUTION di
    JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO
    WHERE o.GENERATION = '5G'
);
--exists
SELECT c.NOM_COMMUNE, c.NOMDEP
FROM basetd.COMMUNE c
WHERE EXISTS (
    SELECT * FROM basetd.DISTRIBUTION di
    JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO
    WHERE di.CODE_INSEE = c.CODE_INSEE AND o.GENERATION = '5G'
);
