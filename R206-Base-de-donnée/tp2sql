--group by
SELECT o.NOMFO, o.TECHNOLOGIE, COUNT(*) AS NB_ANTENNES
FROM basetd.OPERATEUR o
JOIN basetd.DISTRIBUTION di ON o.NUMFO = di.NUMFO
WHERE o.TECHNOLOGIE IN ('5G NR 3500', '5G NR 2100', '5G NR 700')
GROUP BY o.NOMFO, o.TECHNOLOGIE;
-- Sous-requête corrélée annexe f
    SELECT DISTINCT o.NOMFO, o.TECHNOLOGIE, 
    (SELECT COUNT(*) FROM basetd.DISTRIBUTION di 
     WHERE di.NUMFO = o.NUMFO) AS NB_ANTENNES
FROM basetd.OPERATEUR o
WHERE o.TECHNOLOGIE IN ('5G NR 3500', '5G NR 2100', '5G NR 700');



-- 10
--group by
SELECT o.NOMFO, o.TECHNOLOGIE, COUNT(*) AS NB_ANTENNES
FROM basetd.OPERATEUR o
JOIN basetd.DISTRIBUTION di ON o.NUMFO = di.NUMFO
JOIN basetd.COMMUNE c ON di.CODE_INSEE = c.CODE_INSEE
WHERE c.NOM_COMMUNE = 'Nantes'
  AND o.TECHNOLOGIE IN ('5G NR 3500', '5G NR 2100', '5G NR 700')
GROUP BY o.NOMFO, o.TECHNOLOGIE;
--sous requetes corrélée: 
SELECT DISTINCT o.NOMFO, o.TECHNOLOGIE, 
    (SELECT COUNT(*) 
     FROM basetd.DISTRIBUTION di 
     JOIN basetd.COMMUNE c ON di.CODE_INSEE = c.CODE_INSEE
     WHERE di.NUMFO = o.NUMFO 
       AND c.NOM_COMMUNE = 'Nantes') AS NB_ANTENNES
FROM basetd.OPERATEUR o
WHERE o.TECHNOLOGIE IN ('5G NR 3500', '5G NR 2100', '5G NR 700');


--11
--group by
SELECT o.NOMFO, o.TECHNOLOGIE, COUNT(*) AS NB_ANTENNES
FROM basetd.OPERATEUR o
JOIN basetd.DISTRIBUTION di ON o.NUMFO = di.NUMFO
JOIN basetd.COMMUNE c ON di.CODE_INSEE = c.CODE_INSEE
JOIN basetd.DEPARTEMENT d ON c.NOMDEP = d.NOMDEP
WHERE d.CODE_DEPARTEMENT = '44'
  AND o.TECHNOLOGIE IN ('5G NR 3500', '5G NR 2100', '5G NR 700')
GROUP BY o.NOMFO, o.TECHNOLOGIE;
--sous requetes corrélée
SELECT DISTINCT o.NOMFO, o.TECHNOLOGIE, 
    (SELECT COUNT(*) 
     FROM basetd.DISTRIBUTION di 
     JOIN basetd.COMMUNE c ON di.CODE_INSEE = c.CODE_INSEE
     JOIN basetd.DEPARTEMENT d ON c.NOMDEP = d.NOMDEP
     WHERE di.NUMFO = o.NUMFO 
       AND d.CODE_DEPARTEMENT = '44') AS NB_ANTENNES
FROM basetd.OPERATEUR o
WHERE o.TECHNOLOGIE IN ('5G NR 3500', '5G NR 2100', '5G NR 700');
