--5
--group by
SELECT d.NOMDEP, COUNT(c.CODE_INSEE)
FROM basetd.DEPARTEMENT d
LEFT JOIN basetd.COMMUNE c ON d.NOMDEP = c.NOMDEP
GROUP BY d.NOMDEP;
--sous requete corrélée: 
SELECT d.NOMDEP, (SELECT COUNT(*) FROM basetd.COMMUNE c WHERE c.NOMDEP = d.NOMDEP) AS NB_COMMUNES
FROM basetd.DEPARTEMENT d;
--6
--inner join
SELECT c.NOM_COMMUNE, COUNT(*) AS NB_5G
FROM basetd.COMMUNE c
JOIN basetd.DISTRIBUTION di ON c.CODE_INSEE = di.CODE_INSEE
JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO
JOIN basetd.DEPARTEMENT d ON c.NOMDEP = d.NOMDEP
WHERE d.CODE_DEPARTEMENT = '44' AND o.GENERATION = '5G'
GROUP BY c.NOM_COMMUNE
ORDER BY NB_5G ASC;
-- sous requete select
SELECT c.NOM_COMMUNE, 
(SELECT COUNT(*) FROM basetd.DISTRIBUTION di 
 JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO 
 WHERE di.CODE_INSEE = c.CODE_INSEE AND o.GENERATION = '5G') AS NB_5G
FROM basetd.COMMUNE c
JOIN basetd.DEPARTEMENT d ON c.NOMDEP = d.NOMDEP
WHERE d.CODE_DEPARTEMENT = '44'
ORDER BY NB_5G ASC;

--7
--group by/having
SELECT c.NOM_COMMUNE, COUNT(*) AS NB_5G
FROM basetd.COMMUNE c
JOIN basetd.DISTRIBUTION di ON c.CODE_INSEE = di.CODE_INSEE
JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO
JOIN basetd.DEPARTEMENT d ON c.NOMDEP = d.NOMDEP
WHERE d.CODE_DEPARTEMENT = '44' AND o.GENERATION = '5G'
GROUP BY c.NOM_COMMUNE
HAVING COUNT(*) >= 10
ORDER BY NB_5G ASC; 
--sous requete corréelée dans le where : 
SELECT c.NOM_COMMUNE, 
(SELECT COUNT(*) FROM basetd.DISTRIBUTION di 
 JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO 
 WHERE di.CODE_INSEE = c.CODE_INSEE AND o.GENERATION = '5G') AS NB_5G
FROM basetd.COMMUNE c
JOIN basetd.DEPARTEMENT d ON c.NOMDEP = d.NOMDEP
WHERE d.CODE_DEPARTEMENT = '44'
AND (SELECT COUNT(*) FROM basetd.DISTRIBUTION di 
     JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO 
     WHERE di.CODE_INSEE = c.CODE_INSEE AND o.GENERATION = '5G') >= 10
ORDER BY NB_5G ASC;
--8
SELECT c.NOM_COMMUNE, 
    (SELECT COUNT(*) 
     FROM basetd.DISTRIBUTION di 
     JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO 
     WHERE di.CODE_INSEE = c.CODE_INSEE AND o.GENERATION = '5G') AS NB_5G,
    (SELECT COUNT(*) 
     FROM basetd.DISTRIBUTION di 
     JOIN basetd.OPERATEUR o ON di.NUMFO = o.NUMFO 
     WHERE di.CODE_INSEE = c.CODE_INSEE AND o.GENERATION = '4G') AS NB_4G
FROM basetd.COMMUNE c
JOIN basetd.DEPARTEMENT d ON c.NOMDEP = d.NOMDEP
WHERE d.CODE_DEPARTEMENT = '44'
ORDER BY c.NOM_COMMUNE ASC;

