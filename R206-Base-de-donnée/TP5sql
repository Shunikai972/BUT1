-- ============================================================
-- EXERCICE 1.4 - USER_CONSTRAINTS
-- ============================================================

-- Toutes les contraintes de vos tables
SELECT CONSTRAINT_NAME, CONSTRAINT_TYPE, TABLE_NAME, R_CONSTRAINT_NAME, STATUS
FROM USER_CONSTRAINTS
ORDER BY TABLE_NAME;

/*
  EXPLICATION DES COLONNES :

  CONSTRAINT_NAME : Nom de la contrainte.
    - Si vous l'avez nommée explicitement (ex: PK_CLIENT), ce nom apparaît.
    - Sinon Oracle génère un nom automatique du type SYS_Cxxxxxx.

  CONSTRAINT_TYPE : Type de la contrainte, codé sur une lettre :
    - 'P' = PRIMARY KEY       (clé primaire)
    - 'U' = UNIQUE            (unicité)
    - 'C' = CHECK             (vérification, inclut aussi NOT NULL)
    - 'R' = REFERENTIAL       (clé étrangère / intégrité référentielle)
    - 'V' = WITH CHECK OPTION (sur une vue)
    - 'O' = WITH READ ONLY    (sur une vue)

  R_CONSTRAINT_NAME : Renseigné uniquement pour les contraintes de type 'R' (clé étrangère).
    Contient le nom de la contrainte PRIMARY KEY ou UNIQUE référencée dans la table parente.
*/


-- ============================================================
-- EXERCICE 1.5 - USER_CONS_COLUMNS
-- ============================================================

-- Contraintes avec les colonnes associées, pour chaque table
SELECT ucc.TABLE_NAME, ucc.CONSTRAINT_NAME, uc.CONSTRAINT_TYPE,
       ucc.COLUMN_NAME, ucc.POSITION
FROM USER_CONS_COLUMNS ucc
JOIN USER_CONSTRAINTS uc
  ON ucc.CONSTRAINT_NAME = uc.CONSTRAINT_NAME
ORDER BY ucc.TABLE_NAME, ucc.CONSTRAINT_NAME, ucc.POSITION;


