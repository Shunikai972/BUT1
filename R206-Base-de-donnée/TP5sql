-- ============================================================
-- EXERCICE 1.7 - USER_USERS et ALL_USERS
-- ============================================================

-- Informations sur votre propre compte utilisateur
SELECT * FROM USER_USERS;

-- Informations sur tous les utilisateurs de la base
SELECT * FROM ALL_USERS;

/*
  USER_USERS contient (pour l'utilisateur courant) :
    - USERNAME         : nom de l'utilisateur
    - USER_ID          : identifiant interne
    - ACCOUNT_STATUS   : état du compte (OPEN, LOCKED, EXPIRED...)
    - LOCK_DATE        : date de verrouillage éventuel
    - EXPIRY_DATE      : date d'expiration du mot de passe
    - DEFAULT_TABLESPACE : tablespace par défaut pour les objets
    - TEMPORARY_TABLESPACE : tablespace temporaire
    - CREATED          : date de création du compte
    - PROFILE          : profil de sécurité associé

  ALL_USERS contient pour tous les utilisateurs :
    USERNAME, USER_ID, CREATED (moins d'informations que USER_USERS)
*/


