import iut.math.Rational
import org.junit.jupiter.api.Assertions.*
import org.junit.jupiter.api.Test

class TestEqualsRational {

    var r12 = Rational(1, 2)
    var r23 = Rational(2, 3)
    var r43 = Rational(4, 3)
    var r36 = Rational(3,6)

    @Test
    fun testEquals1() {
        assertFalse(r12.equals(r23))
    }

    @Test
    fun testEquals2() {
        assertFalse(r12.equals(r43))
    }

    @Test
    fun testEquals3() {
        assertTrue(r12.equals(r36))
    }

    @Test
    fun testEquals4() {
        assertFalse(r12.equals("1/2"))
    }

    @Test
    fun testEquals6() {
        assertFalse(r12.equals(Any()))
    }

    @Test
    fun testEquals5() {
        val r42 = Rational(4, 2)
        assertTrue(r42.equals(2))
    }

    @Test
    fun test0() {
        assertTrue(r12 == r12)
        assertTrue(r12 == Rational(1, 2))
        assertTrue(Rational(2, 4) == r12)
    }

    @Test
    fun test1() {
        assertTrue(r12 != r23)
        assertFalse(r12 == r23)
    }

    @Test
    fun test2() {
        assertTrue(r23 != r43)
        assertFalse(r43 == r23)
    }

    @Test
    fun test3() {
        assertTrue(r12 != r43)
        assertFalse(r43 == r12)
    }

    @Test
    fun test4() {
        assertFalse(r12 != r36)
        assertTrue(r36 == r12)
    }

    @Test
    fun test5() {
        assertTrue(r12 == Rational(-3,-6))
    }


    @Test
    fun test51() {
        assertTrue(r12 != Rational(3,-6))
    }

    @Test
    fun test52() {
        assertTrue(r12 != Rational(-3,6))
    }


    @Test
    fun test6() {
        assertTrue(Rational(1,-2) == Rational(-3,6))
    }

    @Test
    fun   testSumWithEquals1() {
        val result = r23 + r12  // on peut utiliser le + car il y a la fonction plus()
        assertEquals(Rational(7,6),result)
    }

    @Test
    fun testSumWithEquals2() {
        val result = r23 + r43
        assertEquals(Rational(18,9),result)
    }

    @Test
    fun testSumWithEquals3() {
        val result = r12 + r43
        assertEquals(Rational(11,6),result)
    }

    @Test
    fun testSumWithEquals4() {
        val result = r43 + 0
        assertEquals(Rational(4,3),result)
    }

    @Test
    fun testSumWithEquals5() {
        val result = r43 + 2
        assertEquals(Rational(10,3),result)
    }

    @Test
    fun testSumWithEquals6() {
        val result = r12 + Rational(-1,3)
        assertEquals(Rational(1,6),result)
    }

    @Test
    fun testSumWithEquals7() {
        val result = r43 + (-2)
        assertEquals(Rational(-2,3),result)
    }


    @Test
    fun   testMinusWithEquals1() {
        val result = r23 - r12
        assertEquals(Rational(1,6),result)
    }

    @Test
    fun testMinusWithEquals2() {
        val result = r23 - r43
        assertEquals(Rational(-6,9),result)
    }

    @Test
    fun testMinusWithEquals3() {
        val result = r12 - r43
        assertEquals(Rational(-5,6),result)
    }

    @Test
    fun testMinusWithEquals6() {
        val result = r12 - Rational(-1,3)
        assertEquals(Rational(5,6),result)
    }

    @Test
    fun   testReduceWithEquals1() {
        val ratio = Rational(4,8)
        val result = ratio.reduce()
        assertEquals(Rational(1,2), result)
    }

    @Test
    fun   testReduceWithEquals2() {
        val ratio = Rational(12,3)
        val result = ratio.reduce()
        assertEquals(Rational(4,1), result)

    }

    @Test
    fun   testReduceWithEquals3() {
        val ratio = Rational(5*5*5*5*5*6*7*3, 5*5*5*5*3*3*2)
        val result = ratio.reduce()
        assertEquals(Rational(35,1), result)

    }

    @Test
    fun   testReduceWithEquals4() {
        val ratio = Rational(-12,3)
        val result = ratio.reduce()
        assertEquals(Rational(-4,1), result)
    }


    @Test
    fun   testReduceWithEquals5() {
        val ratio = Rational(12,-3)
        val result = ratio.reduce()
        assertEquals(Rational(-4,1), result)
    }

    @Test
    fun   testReduceWithEquals6() {
        val ratio = Rational(-12,-3)
        val result = ratio.reduce()
        assertEquals(Rational(4,1), result)
    }

}


