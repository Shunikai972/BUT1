import iut.math.Rational

import org.junit.jupiter.api.Assertions.assertEquals
import org.junit.jupiter.api.Test

class TestConvertRational2DoubleOrFloat {

    @Test
    fun test_1() {
        val r = Rational(2,2)
        assertEquals(1.0, r.toDouble(), 0.0)
    }


    @Test
    fun test_2() {
        val r = Rational(4,2)
        assertEquals(2.0, r.toDouble(), 0.0)
    }

    @Test
    fun test_3_2() {
        val r = Rational(3,2)
        assertEquals(1.5, r.toDouble(), 0.0)
    }

    @Test
    fun test_4_3() {
        val r = Rational(4,3)
        assertEquals(1.33333, r.toDouble(), 0.00001)
    }

    @Test
    fun test_1_3() {
        val r = Rational(1,3)
        assertEquals(0.33333, r.toDouble(), 0.00001)
    }

    @Test
    fun test_1float() {
        val r = Rational(2,2)
        assertEquals(1.0f, r.toFloat())
    }


    @Test
    fun test_2float() {
        val r = Rational(4,2)
        assertEquals(2.0f, r.toFloat())
    }

    @Test
    fun test_3_2float() {
        val r = Rational(3,2)
        assertEquals(1.5f, r.toFloat())
    }

    @Test
    fun test_4_3float() {
        val r = Rational(4,3)
        assertEquals(1.3333334f, r.toFloat())
    }

    @Test
    fun test_1_3float() {
        val r = Rational(1,3)
        assertEquals(0.33333334f, r.toFloat())
    }

}